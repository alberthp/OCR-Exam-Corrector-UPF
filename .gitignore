# Virtual environments
omr_env/
omr_env_new/
run_env/

# PyInstaller build artifacts
build/
dist/

# Python bytecode cache
__pycache__/
*.pyc

# pytest cache
.pytest_cache/

# Third-party Poppler binaries (see poppler_bin/README.md to repopulate)
poppler_bin/*
!poppler_bin/README.md

# Review session cache
*.pkl

# Backup files written by apply_answer_key_row_fix() before editing an
# answer key in place -- may contain real exam data, same as the *.csv
# blanket rule above (this pattern alone wouldn't be caught by *.csv).
*.bak

# Windows Explorer folder-view metadata (auto-generated by Explorer on
# folders inside this Drive-synced tree; not part of the project).
desktop.ini

# Real exam/student data (private). examples/ is the promised sanitized
# dataset -- entirely synthetic (fake names/U-numbers/emails), safe to track.
*.pdf
*.xls
*.xlsx
*.csv
!examples/*.pdf
!examples/*.csv
!examples/*.xls
!examples/*.xlsx
output*/

# Claude Code local settings/state (not part of the project)
.claude/

# Packaged executable archives (distributed via GitHub Releases, not git)
*.zip

# GUI launch log (local run artefact)
omr_gui_run.log
